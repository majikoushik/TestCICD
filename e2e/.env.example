# Copy to .env and fill in before running the suite.

# Base URLs — point at whatever environment you're testing.
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api

# Same Mongo connection the server under test uses. Required because:
#   1. global-setup verifies the server is running against a real database
#      (not Synthetic Data Mode — see README.md "Synthetic Data Mode": it
#      resets on restart, which breaks persistence-focused scenarios like A9).
#   2. global-setup upserts one 'superadmin'-role fixture account directly,
#      since there is no self-registration path for that role (by design —
#      server/routes/auth.js rejects admin/superadmin self-registration) and
#      populate_db.js does not seed one.
MONGO_URI=mongodb://localhost:27017/clinictrustai

# Demo accounts (see README.md "Demo Accounts") — all share this password
# after `npm run populate_db` at the repo root.
DEMO_PASSWORD=Demo1234!
PROVIDER_A_EMAIL=john.smith@clinictrustai.com
PROVIDER_B_EMAIL=michael.chen@clinictrustai.com
ADMIN_EMAIL=admin@clinictrustai.com

# Fixture-only — created by global-setup if absent, never used outside this suite.
SUPERADMIN_EMAIL=e2e.superadmin@clinictrustai.com
SUPERADMIN_PASSWORD=Demo1234!
