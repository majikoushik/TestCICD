{
  "env": {
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next", "varsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "no-console": "warn",
    "eqeqeq": "warn",
    "no-var": "warn",
    "prefer-const": "warn",
    "no-duplicate-case": "error",
    "no-unreachable": "warn",
    "no-empty": "warn",
    "no-constant-condition": "warn"
  },
  "ignorePatterns": ["node_modules/", "client/"]
}
