NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_RESET_SECRET=

# Allowed CORS origin (comma-separated for multiple, e.g. https://app.example.com)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ── Polygon EVM (Phase 3) ────────────────────────────────────────────────────
# Leave blank to run in MongoDB-ledger mode (development default).
# When all three are set the server talks to a real EVM node.
#
# Polygon Amoy testnet RPC (free tier): https://rpc-amoy.polygon.technology
POLYGON_RPC_URL=
# Deployed ClinicToken contract address (from: npm run contract:deploy:amoy)
CLINICTOKEN_ADDRESS=
# Platform wallet private key — KEEP SECRET, never commit to git
PRIVATE_KEY=
# Human-readable network name shown in admin UI (amoy | polygon)
POLYGON_NETWORK=amoy
# PolygonScan API key for contract verification (optional)
POLYGONSCAN_API_KEY=

# ── HD Wallet generation ──────────────────────────────────────────────────────
# BIP-39 mnemonic used to derive deterministic wallets for each provider.
# Generate with: node -e "const { ethers } = require('ethers'); console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
# Leave blank to generate a random wallet per user instead.
WALLET_MASTER_MNEMONIC=
# 32-char key used to AES-256-GCM encrypt stored private keys.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
WALLET_ENCRYPTION_KEY=

# ── Multi-sig threshold ───────────────────────────────────────────────────────
# Number of admin approvals required for mint/burn operations (default: 2).
# Set to 1 to disable multi-sig in single-admin environments.
TOKEN_MULTISIG_REQUIRED=2
