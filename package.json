{
  "name": "clinictrust-ai",
  "version": "1.0.0",
  "description": "Blockchain-based healthcare platform for secure patient record sharing, AI analytics, and token-based incentives",
  "main": "index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start-dev": "node start-dev.js",
    "populate_db": "node populate_db.js",
    "get_data_from_db": "node get_data_from_db.js",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "blockchain:start": "cd blockchain && ./startFabric.sh",
    "blockchain:stop": "cd blockchain && ./stopFabric.sh",
    "contract:compile": "npx hardhat compile",
    "contract:deploy:amoy": "npx hardhat run contracts/scripts/deploy.js --network amoy",
    "contract:deploy:local": "npx hardhat run contracts/scripts/deploy.js --network hardhat"
  },
  "keywords": [
    "healthcare",
    "blockchain",
    "AI",
    "smart-contracts",
    "token-economy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.17.0",
    "express": "^4.18.2",
    "express-graphql": "^0.12.0",
    "express-rate-limit": "^8.5.2",
    "fabric-network": "^2.2.16",
    "graphql": "^15.10.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^9.0.1",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "eslint": "^8.57.1",
    "nodemon": "^2.0.22",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.22.0"
  }
}
